# ============================================
# ZSDEVWEB — Variables d'environnement
# Copiez ce fichier en .env et remplissez les valeurs
# ============================================

# Django
SECRET_KEY=django-insecure-change-me-in-production-use-50-random-chars
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DJANGO_SETTINGS_MODULE=zsdevweb.settings.development

# Database PostgreSQL
POSTGRES_DB=zsdevweb
POSTGRES_USER=zsdevweb
POSTGRES_PASSWORD=devpassword
DATABASE_URL=postgresql://zsdevweb:devpassword@db:5432/zsdevweb

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Email (console en dev, SMTP en prod)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Zsdevweb <contact@zsdevweb.fr>

# Frontend (Vite)
VITE_API_URL=http://localhost:8000
VITE_APP_NAME=Zsdevweb
VITE_APP_URL=http://localhost:5173

# URL publique du frontend (utilisée dans les emails)
FRONTEND_URL=http://localhost:5173

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# Media / Static
MEDIA_ROOT=/app/media
STATIC_ROOT=/app/staticfiles

# Sécurité (production seulement)
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
