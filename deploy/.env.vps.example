# ============================================================
# Variables d'environnement pour déploiement VPS
# Copiez en .env et remplissez toutes les valeurs
# ============================================================

# Django
SECRET_KEY=CHANGEZ-MOI-AVEC-50-CARACTERES-ALEATOIRES
DEBUG=False
ALLOWED_HOSTS=zsdevweb.fr,www.zsdevweb.fr
DJANGO_SETTINGS_MODULE=zsdevweb.settings.production

# Domaine (sans https://)
DOMAIN=zsdevweb.fr

# Base de données PostgreSQL
POSTGRES_DB=zsdevweb
POSTGRES_USER=zsdevweb
POSTGRES_PASSWORD=MOT_DE_PASSE_FORT_ICI
DATABASE_URL=postgresql://zsdevweb:MOT_DE_PASSE_FORT_ICI@db:5432/zsdevweb

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Email (SMTP en production)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=votre-email@gmail.com
EMAIL_HOST_PASSWORD=mot-de-passe-application-gmail
DEFAULT_FROM_EMAIL=Zsdevweb <contact@zsdevweb.fr>

# Frontend
FRONTEND_URL=https://zsdevweb.fr
VITE_API_URL=https://zsdevweb.fr
VITE_APP_NAME=Zsdevweb
VITE_APP_URL=https://zsdevweb.fr

# CORS
CORS_ALLOWED_ORIGINS=https://zsdevweb.fr,https://www.zsdevweb.fr

# Docker Hub (pour le déploiement CI/CD)
DOCKER_USERNAME=votre-username-dockerhub

# Traefik (Let's Encrypt)
ACME_EMAIL=contact@zsdevweb.fr
# Générer avec : docker run --rm httpd:2.4-alpine htpasswd -nb admin MON_MOT_DE_PASSE
# Les $ doivent être doublés : $$ dans le fichier .env
TRAEFIK_DASHBOARD_AUTH=admin:$$apr1$$...

# Sécurité Django (production)
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
